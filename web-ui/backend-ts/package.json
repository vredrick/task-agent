  "description": "TypeScript backend for Task Agent Web UI using @anthropic-ai/claude-code SDK",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit"
